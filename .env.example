# 이 파일을 .env 로 복사한 뒤 값을 채우세요. .env 는 gitignore 되어 있습니다.
#   cp .env.example .env

# Neon PostgreSQL 연결 문자열 (Neon 대시보드 > Connection string > Prisma)
# 반드시 sslmode=require 포함
#
# 배포 DB 를 그대로 쓰지 마세요. 여러 명이 DB 하나를 같이 쓰면 누가 스키마를 밀어넣는
# 순간 나머지 사람과 배포가 같이 깨집니다. Neon 대시보드에서 dev-<이름> 브랜치를
# 만들어 자기 것을 쓰세요. (README > 데이터베이스)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# db push / db seed 를 막을 호스트 목록(쉼표로 구분). 운영 DB 엔드포인트를 적어두면,
# 실수로 운영 연결 문자열을 위에 붙여넣어도 파괴적인 명령이 멈춥니다.
# -pooler 가 붙은 호스트는 같은 것으로 취급하니 하나만 적어도 됩니다.
PROTECTED_DB_HOSTS="ep-xxxx.ap-southeast-1.aws.neon.tech"

# 세션 쿠키(JWT) 서명 키 — 최소 32바이트. 생성: openssl rand -base64 32
# 값을 바꾸면 발급된 세션이 전부 무효화됩니다.
SESSION_SECRET=""

# 로그인 비밀번호는 환경변수가 아닙니다. 직원마다 계정을 갖고, 관리자가 임직원
# 관리에서 초기 비밀번호를 발급합니다. (예전의 ACCESS_PASSWORD / ADMIN_PASSWORD 는
# 없어졌습니다 — .env 에 남아 있으면 지워도 됩니다)
#
# 첫 관리자만 화면이 없으니 스크립트로 만듭니다:
#   pnpm admin:password <이메일>

# 서명 HTML / vCard 안에 들어갈 절대 URL 의 베이스. 배포 시 실제 도메인으로 교체.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# UploadThing 이미지 업로드 토큰 (대시보드 > API Keys). 업로드 구현 전까지는 비워둬도 됩니다.
UPLOADTHING_TOKEN=""
