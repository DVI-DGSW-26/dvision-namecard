# 이 파일을 .env 로 복사한 뒤 값을 채우세요. .env 는 gitignore 되어 있습니다.
#   cp .env.example .env

# Neon PostgreSQL 연결 문자열 (Neon 대시보드 > Connection string > Prisma)
# 반드시 sslmode=require 포함
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# 세션 쿠키(JWT) 서명 키 — 최소 32바이트. 생성: openssl rand -base64 32
# 값을 바꾸면 발급된 세션이 전부 무효화됩니다.
SESSION_SECRET=""

# 직원 공용 비밀번호. 사내 공지로 링크와 함께 배포합니다.
ACCESS_PASSWORD=""

# 관리자 비밀번호 (직원 추가 / 회사 정보 수정). ACCESS_PASSWORD 와 반드시 다르게 설정하세요.
ADMIN_PASSWORD=""

# 서명 HTML / vCard 안에 들어갈 절대 URL 의 베이스. 배포 시 실제 도메인으로 교체.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# UploadThing 이미지 업로드 토큰 (대시보드 > API Keys). 업로드 구현 전까지는 비워둬도 됩니다.
UPLOADTHING_TOKEN=""
