generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"

  /**
   * relationJoins — include 를 LATERAL JOIN 한 방에 처리하게 해 줍니다.
   *
   * 기본값은 관계마다 SELECT 를 따로 보내는 방식이라, 명함 한 장을 읽는 데
   * (직원·회사·사업장·직위·임원직책·직책) 여섯 번을 왕복합니다. DB 가 싱가포르에
   * 있어 왕복 한 번이 약 80ms 이므로 그것만으로 반 초에 가깝습니다.
   *
   * 쓰는 곳은 relationLoadStrategy: "join" 을 붙인 조회뿐입니다. 안 붙인 조회는
   * 지금까지와 똑같이 동작하므로, 이 기능이 문제를 일으키면 그 줄만 지우면 됩니다.
   */
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

enum Status {
  PENDING
  ACTIVE
  RESIGNED
}

/**
 * 조직 목록 3종 — 직위 · 임원 직책 · 직책.
 *
 * enum 이 아니라 테이블인 이유: 관리자가 /admin/org 에서 직접 추가·수정·삭제합니다.
 * enum 이면 목록 하나 바꾸는 데 코드 수정과 배포가 필요합니다.
 *
 * 셋 다 모양이 같습니다(name · nameEn · sortOrder). 한 테이블에 kind 컬럼으로
 * 합치지 않은 이유는 Employee 가 세 개를 각각 참조하기 때문입니다 — 합치면
 * "직위 칸에 직책이 들어가는" 조합을 DB 가 막지 못합니다.
 *
 * 삭제하면 그 값을 쓰던 직원의 칸이 비워집니다(onDelete: SetNull). 직원 행이
 * 사라지거나 삭제가 거부되지 않습니다.
 */

/// 직위 — 매니저 · 연구원 · 엔지니어 트랙의 단계(매니저 ~ 수석엔지니어).
model Rank {
  id     String @id @default(cuid())
  name   String @unique
  nameEn String

  /// 선택 상자에 보이는 순서. 관리자가 숫자로 바꿉니다.
  sortOrder Int @default(0)

  employees Employee[]
}

/// 임원 직책 — 대표이사 · 기술총괄 등. 영문은 약어(CEO)와 정식 명칭을 따로 둡니다.
model ExecutiveTitle {
  id         String @id @default(cuid())
  name       String @unique
  /// 약어. 명함에 짧게 넣을 때 씁니다. (CEO)
  nameEn     String
  /// 정식 명칭. (Chief Executive Officer)
  nameEnFull String

  sortOrder Int @default(0)

  employees Employee[]
}

/// 직책 — 고문 · 연구소장 · 팀장 · 팀원 · 공장총괄. 임원 직책과 동시에 가질 수 있습니다.
model Position {
  id     String @id @default(cuid())
  name   String @unique
  nameEn String

  sortOrder Int @default(0)

  employees Employee[]
}

/**
 * 부서 — 팀과 파트의 2단계입니다. (경영관리 팀 > 회계/재무 파트)
 *
 * 예전에는 Employee.department 자유 입력 한 칸이었습니다. 두 단계를 한 칸에 적으면
 * "경영관리", "경영관리/회계", "회계재무" 가 전부 다른 부서로 갈라져서 나눴습니다.
 */

/// 부서 — 팀. 위 단계입니다.
model Team {
  id     String @id @default(cuid())
  name   String @unique
  nameEn String

  sortOrder Int @default(0)

  parts     Part[]
  employees Employee[]
}

/// 부서 — 파트. 반드시 한 팀에 속합니다. 팀을 지우면 그 팀의 파트도 함께 사라집니다.
model Part {
  id     String @id @default(cuid())
  name   String
  nameEn String

  sortOrder Int @default(0)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  employees Employee[]

  // 이름은 팀 안에서만 유일하면 됩니다 — 다른 팀에 같은 이름의 파트가 있을 수 있습니다.
  @@unique([teamId, name])
  @@index([teamId])
}

/**
 * 사업장 — 본사 · R&D센터처럼 회사가 가진 주소입니다.
 *
 * Company.address 한 칸이었던 걸 표로 뺐습니다. 주소가 둘 이상이면 한 칸에 넣을
 * 수 없고, 명함에는 가진 사업장이 전부 찍힙니다. 관리자가 /admin/org 에서 늘립니다.
 */
model Office {
  id String @id @default(cuid())

  /// 사업장 이름(본사 · R&D센터). 명함에는 찍지 않고 관리 화면에서 구분용으로만 씁니다.
  name String

  /// 우편번호. 국문 명함에는 `(43011) 대구시 …` 처럼 주소 앞에 괄호로 붙습니다.
  postalCode String
  address    String

  /**
   * 영문 주소. 영문 명함(/c/[slug]/en)이 이 값을 씁니다.
   *
   * 국문처럼 우편번호를 앞에 붙이지 않고 적힌 그대로 내보냅니다 — 영문 주소는
   * 우편번호가 끝에 오는 표기가 표준이라, 통째로 적어 두는 편이 정확합니다.
   * 비어 있으면 영문 카드에서 그 줄이 빠집니다.
   */
  addressEn String?

  sortOrder Int @default(0)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Company {
  id             String   @id @default(cuid())
  nameKo         String
  nameEn         String
  tel            String
  fax            String?
  logoUrl        String

  /**
   * 공개 카드 아래 아이콘 줄에 걸리는 주소들.
   *
   * 값이 빈 항목은 아이콘째 숨깁니다 — 회사가 SNS 하나를 접어도 깨진 링크가
   * 남지 않습니다. 홈페이지만 예외로, 비어 있으면 config/brand.ts 의 기본 주소로
   * 떨어져 아이콘이 사라지지 않습니다.
   *
   * 스킴 없이 "dvi-ind.com" 처럼 저장돼도 됩니다. 카드가 붙여서 엽니다.
   */
  homepageUrl String?
  /// 영문 홈페이지. 비어 있으면 영문 카드도 국문 홈페이지를 겁니다.
  homepageUrlEn String?
  linkedinUrl   String?
  /// 채널이 아니라 회사 소개 영상입니다. 국문 카드가 씁니다.
  youtubeUrl   String?
  /// 영문 소개 영상. 비어 있으면 영문 카드도 국문 영상을 겁니다.
  youtubeUrlEn String?
  instagramUrl String?

  brandColor     String   @default("#931B82")
  tagline        String?
  certifications Json

  /**
   * 영문 인증 뱃지. 영문 카드가 이 값만 씁니다.
   * 국문 값으로 떨어지지 않습니다 — "IATF 16949" 처럼 원래 영문인 항목이 많아
   * 그냥 써도 되어 보이지만, 관리자가 "품질경영시스템 인증" 을 한 줄 추가하는
   * 순간 영문 명함에 한글이 박힙니다. 다른 영문 칸과 같은 규칙으로 둡니다.
   * 비어 있으면 영문 카드에서 뱃지 줄이 통째로 빠집니다.
   */
  certificationsEn Json @default("[]")

  industry String? // 사업 분야: "알루미늄 압출 · 정밀가공"

  // 영문 카드가 쓰는 값. 비어 있으면 영문 카드에서 그 줄이 빠집니다 —
  // 한글을 대신 넣지 않습니다. 영문 명함에 한글이 섞이면 안 만든 것만 못합니다.
  industryEn String?
  taglineEn  String?

  offices   Office[]
  employees Employee[]
}

// 개인 계정이 없는 구조입니다. 인증은 공용 비밀번호 1개 + httpOnly 쿠키로만 이뤄지므로
// Employee 에는 비밀번호/역할 컬럼을 두지 않습니다. (lib/auth.ts 참고)
model Employee {
  id    String @id @default(cuid())
  slug  String @unique
  email String @unique

  // vCard N 필드(`류;영균;;;`)를 정확히 만들기 위해 성/이름을 분리 저장한다. 합치지 말 것.
  nameKo     String
  familyName String
  givenName  String
  nameEn     String?

  // 직위 · 임원 직책 · 직책. 셋 다 목록에서 고르는 값이고, 셋 다 비어 있을 수 있습니다.
  //
  // 필수인 직위까지 nullable 인 이유: 관리자가 목록에서 항목을 지우면 그 값을 쓰던
  // 직원의 칸이 비워집니다(SetNull). 여기서 not null 을 걸면 삭제 자체가 실패합니다.
  // 폼은 여전히 직위를 고르도록 유도하고, 비어 있으면 명함에서 통째로 빠집니다.
  rankId String?
  rank   Rank?   @relation(fields: [rankId], references: [id], onDelete: SetNull)

  executiveTitleId String?
  executiveTitle   ExecutiveTitle? @relation(fields: [executiveTitleId], references: [id], onDelete: SetNull)

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  // 부서는 팀 · 파트 2단계입니다. 파트만 고르고 팀을 비우는 건 폼에서 막습니다.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  partId String?
  part   Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)

  credential String?
  /// 자격·학위의 영문 표기 (공학박사 → Ph.D.). 비면 영문 카드에서 빠집니다.
  credentialEn String?
  bio          String? @db.VarChar(80)

  telWork      String?
  telMobile    String?
  mobilePublic Boolean @default(false)
  photoUrl     String?

  status Status @default(PENDING)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  views ProfileView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([rankId])
  @@index([executiveTitleId])
  @@index([positionId])
  @@index([teamId])
  @@index([partId])
}

model ProfileView {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  action     String
  createdAt  DateTime @default(now())

  @@index([employeeId, createdAt])
}
