generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rank {
  사원
  주임
  대리
  과장
  차장
  부장
  이사
  대표이사
}

enum Status {
  PENDING
  ACTIVE
  RESIGNED
}

model Company {
  id             String   @id @default(cuid())
  nameKo         String
  nameEn         String
  address        String
  tel            String
  fax            String?
  logoUrl        String
  homepageUrl    String?
  brandColor     String   @default("#931B82")
  tagline        String?
  certifications Json

  industry String? // 사업 분야: "알루미늄 압출 · 정밀가공"

  employees Employee[]
}

// 개인 계정이 없는 구조입니다. 인증은 공용 비밀번호 1개 + httpOnly 쿠키로만 이뤄지므로
// Employee 에는 비밀번호/역할 컬럼을 두지 않습니다. (lib/auth.ts 참고)
model Employee {
  id    String @id @default(cuid())
  slug  String @unique
  email String @unique

  // vCard N 필드(`류;영균;;;`)를 정확히 만들기 위해 성/이름을 분리 저장한다. 합치지 말 것.
  nameKo     String
  familyName String
  givenName  String
  nameEn     String?

  rank       Rank
  // 직책(팀장·본부장·공장장). 직급(rank)과 별개입니다 — 같은 부장이어도 직책은 다를 수 있습니다.
  position   String?
  department String?
  credential String?
  bio        String? @db.VarChar(80)

  telWork      String?
  telMobile    String?
  mobilePublic Boolean @default(false)
  photoUrl     String?

  status Status @default(PENDING)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  views ProfileView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model ProfileView {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  action     String
  createdAt  DateTime @default(now())

  @@index([employeeId, createdAt])
}
