generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rank {
  사원
  주임
  대리
  과장
  차장
  부장
  이사
  대표이사
}

enum Status {
  PENDING
  ACTIVE
  RESIGNED
}

model Company {
  id             String   @id @default(cuid())
  nameKo         String
  nameEn         String
  address        String
  tel            String
  fax            String?
  logoUrl        String
  homepageUrl    String?
  brandColor     String   @default("#931B82")
  tagline        String?
  certifications Json

  // 공개 프로필 카드의 회사 지표. Json(stats) 대신 명시적 컬럼으로 둡니다 —
  // zod 검증과 폼 바인딩이 훨씬 단순해지고, 오타 난 키가 조용히 통과하지 않습니다.
  industry       String? // 사업 분야: "알루미늄 압출 · 정밀가공"
  foundedYear    Int? // 설립연도
  capacity       Int? // 연간 생산능력 (T/년)
  equipmentCount Int? // 보유 설비 (대)
  employeeCount  Int? // 임직원 (명)

  employees Employee[]
}

// 개인 계정이 없는 구조입니다. 인증은 공용 비밀번호 1개 + httpOnly 쿠키로만 이뤄지므로
// Employee 에는 비밀번호/역할 컬럼을 두지 않습니다. (lib/auth.ts 참고)
model Employee {
  id    String @id @default(cuid())
  slug  String @unique
  email String @unique

  // vCard N 필드(`류;영균;;;`)를 정확히 만들기 위해 성/이름을 분리 저장한다. 합치지 말 것.
  nameKo     String
  familyName String
  givenName  String
  nameEn     String?

  rank       Rank
  department String?
  credential String?
  bio        String? @db.VarChar(80)

  telWork      String?
  telMobile    String?
  mobilePublic Boolean @default(false)
  photoUrl     String?

  status Status @default(PENDING)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  views ProfileView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model ProfileView {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  action     String
  createdAt  DateTime @default(now())

  @@index([employeeId, createdAt])
}
